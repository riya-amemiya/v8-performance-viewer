---
// One benchmark card: a horizontal bar of median ops/sec per version across
// the versions named in the bench config, a headline badge for the newest
// version versus the reference (the first version), and a table view with
// the full statistics. Bars share one hue because they are the same metric
// (throughput) across versions; the version label beside each bar carries
// identity, and the reference-relative percent rides each non-reference bar.
const { result } = Astro.props;
const versions = result.versions;
const reference = versions.find((v: any) => v.reference) ?? versions[0];
const newest = versions[versions.length - 1];

const max = Math.max(...versions.map((v: any) => v.stats.median));

const fmtCompact = new Intl.NumberFormat('en', { notation: 'compact', maximumFractionDigits: 1 });
const fmtFull = new Intl.NumberFormat('en');

const headlinePct = newest.percentVsReference;
const headlineGood = headlinePct >= 0;
const headlineVar = headlineGood ? 'var(--delta-good)' : 'var(--delta-bad)';

function deltaLabel(pct: number): string {
  return `${pct >= 0 ? '+' : ''}${pct.toFixed(1)}%`;
}

function tipText(run: any): string {
  const lines = [
    `${run.spec} (${run.resolved})${run.reference ? ' — reference' : ''}`,
    `median ${fmtFull.format(Math.round(run.stats.median))} ops/s`,
    `mean ${fmtFull.format(Math.round(run.stats.mean))} ± ${fmtFull.format(Math.round(run.stats.stddev))}`,
    `CV ${(run.stats.cv * 100).toFixed(1)}%`,
    `${run.samples.length} samples × ${fmtFull.format(run.innerIterations)} iterations`,
    `d8 ${run.d8Version}`,
  ];
  if (!run.reference) {
    lines.splice(1, 0, `${deltaLabel(run.percentVsReference)} vs ${reference.spec}`);
  }
  return lines.join('\n');
}
---

<section class="rounded-2xl border border-ring bg-surface-1 p-5 sm:p-6">
  <header class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-2">
    <div class="min-w-0">
      <h2 class="text-base font-semibold">{result.name}</h2>
      <p class="mt-0.5 truncate font-mono text-xs text-ink-muted">
        {`${result.dir ?? `bench/${result.name}`}/${result.bench.replace(/^\.\//, '')}`}
      </p>
    </div>
    <span
      class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-sm font-semibold"
      style={`color:${headlineVar};background:color-mix(in srgb, ${headlineVar} 11%, transparent)`}
      title={`${newest.spec} vs ${reference.spec} (reference)`}
    >
      <span aria-hidden="true">{headlineGood ? '▲' : '▼'}</span>
      {deltaLabel(headlinePct)}
      <span class="font-normal opacity-80">{newest.spec} vs {reference.spec}</span>
    </span>
  </header>

  <div class="mt-5 space-y-2">
    {
      versions.map((run: any) => {
        const pct = (run.stats.median / max) * 100;
        const inside = pct > 72;
        const delta = run.reference ? null : run.percentVsReference;
        const deltaVar = delta === null ? '' : delta >= 0 ? 'var(--delta-good)' : 'var(--delta-bad)';
        return (
          <div
            class="flex items-center gap-3 py-0.5"
            data-tip={tipText(run)}
            aria-label={`${run.spec}, median ${fmtFull.format(Math.round(run.stats.median))} ops per second${run.reference ? ', reference' : `, ${deltaLabel(run.percentVsReference)} vs ${reference.spec}`}`}
          >
            <span class="flex w-24 shrink-0 items-center gap-1.5 sm:w-32" title={run.resolved}>
              <span class="truncate text-sm text-ink-2">{run.spec}</span>
              {run.reference && (
                <span class="shrink-0 rounded-sm border border-ring px-1 text-[10px] leading-4 text-ink-muted">ref</span>
              )}
            </span>
            <div class="relative h-5 flex-1">
              <div class="absolute inset-y-0 left-0 rounded-r-[4px] bg-series-baseline" style={`width:${Math.max(pct, 0.5)}%`} />
              {inside ? (
                <span
                  class="absolute inset-y-0 left-0 flex items-center justify-end pr-2 text-xs font-medium text-on-baseline"
                  style={`width:${pct}%`}
                >
                  {fmtCompact.format(run.stats.median)}
                </span>
              ) : (
                <span
                  class="absolute inset-y-0 flex items-center text-xs font-medium text-ink-2"
                  style={`left:calc(${pct}% + 8px)`}
                >
                  {fmtCompact.format(run.stats.median)}
                </span>
              )}
            </div>
            <span class="w-16 shrink-0 text-right text-xs font-medium tabular-nums" style={delta === null ? 'color:var(--ink-muted)' : `color:${deltaVar}`}>
              {delta === null ? 'ref' : deltaLabel(delta)}
            </span>
          </div>
        );
      })
    }
  </div>

  <details class="mt-4 text-sm">
    <summary class="cursor-pointer select-none text-ink-muted transition-colors hover:text-ink-2">Details</summary>
    <div class="mt-2 overflow-x-auto">
      <table class="w-full min-w-140 text-left text-xs tabular-nums">
        <thead>
          <tr class="text-ink-muted">
            <th class="py-1.5 pr-3 font-normal">version</th>
            <th class="py-1.5 pr-3 font-normal">median ops/s</th>
            <th class="py-1.5 pr-3 font-normal">vs {reference.spec}</th>
            <th class="py-1.5 pr-3 font-normal">mean</th>
            <th class="py-1.5 pr-3 font-normal">stddev</th>
            <th class="py-1.5 pr-3 font-normal">CV</th>
            <th class="py-1.5 pr-3 font-normal">samples</th>
            <th class="py-1.5 pr-3 font-normal">iters/sample</th>
            <th class="py-1.5 font-normal">commit</th>
          </tr>
        </thead>
        <tbody>
          {
            versions.map((run: any) => (
              <tr class="border-t border-grid">
                <td class="py-1.5 pr-3">
                  <span class="inline-flex items-center gap-1.5">
                    <span class="h-2.5 w-2.5 shrink-0 rounded-[3px] bg-series-baseline" />
                    <span class="text-ink-1">{run.spec}</span>
                    {run.reference && <span class="text-ink-muted">ref</span>}
                    <span class="text-ink-muted">{run.d8Version}</span>
                  </span>
                </td>
                <td class="py-1.5 pr-3 font-medium">{fmtFull.format(Math.round(run.stats.median))}</td>
                <td class="py-1.5 pr-3" style={run.reference ? 'color:var(--ink-muted)' : `color:${run.percentVsReference >= 0 ? 'var(--delta-good)' : 'var(--delta-bad)'}`}>
                  {run.reference ? '—' : deltaLabel(run.percentVsReference)}
                </td>
                <td class="py-1.5 pr-3">{fmtFull.format(Math.round(run.stats.mean))}</td>
                <td class="py-1.5 pr-3">{fmtFull.format(Math.round(run.stats.stddev))}</td>
                <td class="py-1.5 pr-3">{(run.stats.cv * 100).toFixed(1)}%</td>
                <td class="py-1.5 pr-3">{run.samples.length}</td>
                <td class="py-1.5 pr-3">{fmtFull.format(run.innerIterations)}</td>
                <td class="py-1.5 font-mono">{run.sha.slice(0, 7)}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </details>
</section>
